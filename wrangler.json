{
  "name": "invert-server",
  "main": "server/index.ts",
  "compatibility_date": "2024-04-03",
  "vars": {
    "CORS_ORIGIN": "*"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "invertdb",
      "database_id": "75e8ba05-8e59-4d3a-a41b-fc916c0490be",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "GAME_ROOM",
        "class_name": "GameRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "GameRoom"
      ]
    }
  ],
  "observability": {
    "enabled": true
  }
}
