# --- Vite (browser; copy to `.env` / `.env.local`; never commit real secrets) ---

# WebSocket URL of your deployed Worker — REST economy API uses the same host (wss → https).
# Omit for local dev → defaults to ws://127.0.0.1:8787 (local Wrangler D1, not Cloudflare Studio remote).
VITE_MULTIPLAYER_URL=wss://YOUR-WORKER.workers.dev

# Optional gate when hosting the static build
# VITE_PASSWORD=

# --- Cloudflare Worker + D1 (not loaded by Vite — configure in repo + dashboard) ---

# D1 binding: see `wrangler.json` → `d1_databases` (`database_name`, `database_id`). Runtime: `env.DB` in Worker code.
# Apply schema: `npx wrangler d1 migrations apply invertdb --remote`

# Optional Worker var `CORS_ORIGIN`: set to one origin (e.g. https://your-app.vercel.app) or leave unset / `*` so the API echoes `Origin` (fixes cross-origin from Vercel).
